# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── Queue / Redis ────────────────────────────────────────────────────────────
# Use a managed Redis URL in production (Upstash, Redis Cloud, etc.)
REDIS_URL=redis://localhost:6379
WORKER_CONCURRENCY=2

# ─── Authentication ───────────────────────────────────────────────────────────
# Shared secret between this worker and the main Lovable backend.
# Set the same value in the Lovable backend's RENDER_WORKER_API_KEY env var.
WORKER_API_KEY=change-me-before-deploy

# ─── Resource limits ──────────────────────────────────────────────────────────
JOB_TIMEOUT_SECONDS=600
MAX_CLIPS=20
MAX_DURATION_SECONDS=600
MAX_DOWNLOAD_BYTES=2147483648   # 2 GB across all files in a single job

# ─── Network & I/O ────────────────────────────────────────────────────────────
DOWNLOAD_TIMEOUT_SECONDS=60
TEMP_DIR=/tmp/render-tmp
OUTPUT_DIR=/tmp/renders

# ─── SSRF allowlist ───────────────────────────────────────────────────────────
# Comma-separated list of hostnames the worker is allowed to fetch from.
# Add your Supabase project hostname: <project>.supabase.co
URL_ALLOWLIST=videos.pexels.com,cdn.pixabay.com,player.vimeo.com,localhost

# ─── BullMQ job retry ─────────────────────────────────────────────────────────
JOB_ATTEMPTS=3
JOB_BACKOFF_DELAY_MS=5000

# ─── Node env ─────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
