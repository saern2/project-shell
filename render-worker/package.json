{
  "name": "render-worker",
  "version": "1.0.0",
  "description": "Standalone video-rendering worker service with BullMQ job queue",
  "main": "src/server.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "worker": "node src/worker.js",
    "test": "jest --runInBand --forceExit",
    "test:unit": "jest tests/unit --runInBand --forceExit",
    "test:integration": "jest tests/integration --runInBand --forceExit",
    "generate-clips": "bash scripts/generate_test_clips.sh"
  },
  "dependencies": {
    "bullmq": "^5.12.0",
    "express": "^4.19.2",
    "fluent-ffmpeg": "^2.1.3",
    "ioredis": "^5.4.1",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^29.7.0",
    "jest": "^29.7.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 300000,
    "globalSetup": "./tests/globalSetup.js",
    "globalTeardown": "./tests/globalTeardown.js"
  }
}
